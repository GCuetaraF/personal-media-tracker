{
  "name": "personal-media-tracker",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --outDir dist --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude \"**/*.db.test.ts\"",
    "test:db": "vitest run \"**/*.db.test.ts\"",
    "check": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "dotenv": "^17.2.3",
    "google-auth-library": "^10.5.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/node": "^25.0.3",
    "esbuild": "^0.21.2",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.10.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.6.0"
  }
}
